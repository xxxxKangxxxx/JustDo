# Just Do — web env vars
#
# Copy to `.env.local` and fill in values for your environment.
# Local Supabase: run `supabase status -o env` from the repo root and copy
# `API_URL` -> NEXT_PUBLIC_SUPABASE_URL and `ANON_KEY` -> NEXT_PUBLIC_SUPABASE_ANON_KEY.
#
# Anything prefixed with NEXT_PUBLIC_ is exposed to the browser bundle.
# SUPABASE_SERVICE_ROLE_KEY must NEVER be exposed to the client — only use it
# from server-only code (API routes, server actions, Edge Functions).
#
# === Amplify (production) registration ===
# Register the following in Amplify Console → App settings → Environment variables:
#   - NEXT_PUBLIC_SUPABASE_URL          (public, baked into client bundle at build)
#   - NEXT_PUBLIC_SUPABASE_ANON_KEY     (public)
#   - NEXT_PUBLIC_AUTH_GOOGLE_ENABLED   (public, "true")
#   - NEXT_PUBLIC_AUTH_APPLE_ENABLED    (public, "false" until Apple flow is ready)
#   - NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY (public, live key once Toss merchant review passes)
#   - NEXT_PUBLIC_IOS_APP_STORE_URL     (public, set once App Store listing exists)
#   - SUPABASE_SERVICE_ROLE_KEY         (server-only, do NOT enable "branch override" with NEXT_PUBLIC_)
#   - TOSS_PAYMENTS_SECRET_KEY          (server-only, live key once Toss merchant review passes)
#   - BILLING_CRON_SECRET               (server-only, generate with `openssl rand -base64 32`)
#
# The SUPABASE_AUTH_EXTERNAL_* vars below are for Supabase CLI / local config.toml only.
# In hosted Supabase they are set inside the Supabase dashboard — do NOT register them in Amplify.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Client-visible auth provider switches. Keep Apple disabled until the Apple
# developer credential flow is configured.
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=true
NEXT_PUBLIC_AUTH_APPLE_ENABLED=false

# OAuth provider credentials consumed by Supabase CLI/config locally.
# In hosted Supabase, set these in the dashboard instead.
# Local callback URL: http://127.0.0.1:3000/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=

# Server-only. Leave blank if you do not run server code that needs it.
SUPABASE_SERVICE_ROLE_KEY=

# Toss Payments billing. Test keys can be used before merchant review; live
# automatic billing requires Toss contract/review and an automatic-billing MID.
NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=
BILLING_CRON_SECRET=

# iOS App Store URL surfaced by the mobile web guide. Leave blank until the
# public App Store listing exists. While blank the guide keeps the static
# "iOS 앱 기준" copy and the iOS download button stays disabled. Once set,
# iOS mobile browser visits auto-redirect to this URL, and the button links
# to it.
NEXT_PUBLIC_IOS_APP_STORE_URL=
